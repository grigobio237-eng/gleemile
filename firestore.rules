rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 💡 공통 헬퍼: 특정 팀 멤버의 권한(Role) 확인
    // id가 `${teamId}_${userId}` 인 문서를 조회하여 role을 반환합니다.
    function getTeamMemberRole(teamId, userId) {
      let memberDoc = get(/databases/$(database)/documents/team_members/$(teamId + '_' + userId));
      return memberDoc != null ? memberDoc.data.role : null;
    }

    // 💡 공통 헬퍼: 참관인(Supporter)의 연결된 자녀 ID 확인
    function getLinkedPlayerId(teamId, userId) {
      let memberDoc = get(/databases/$(database)/documents/team_members/$(teamId + '_' + userId));
      return memberDoc != null ? memberDoc.data.linkedPlayerId : null;
    }

    // =======================================================
    // [Bucket 1] 유저 프로필 및 멤버 권한 도메인
    // =======================================================

    match /users/{userId} {
      // 민감 정보(users): 본인만 읽고 쓸 수 있음
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /user_profiles/{userId} {
      // 공개 프로필(user_profiles): 로그인한 누구나 조회 가능, 쓰기는 본인만
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /team_codes/{teamCode} {
      // 초대 코드 중복 검증용 룩업: 로그인한 누구나 조회 가능, 생성은 겹치지 않을 때만 가능, 수정 불가
      allow read: if request.auth != null;
      allow create: if request.auth != null && !exists(/databases/$(database)/documents/team_codes/$(teamCode));
      allow update, delete: if false;
    }

    match /team_members/{memberId} {
      // 본인이 속한 멤버십 정보이거나, 소속 팀 방장/임원이면 조회 가능
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        getTeamMemberRole(resource.data.teamId, request.auth.uid) in ['director', 'manager']
      );
      
      // 쓰기는 가입/탈퇴를 위해 본인 또는 방장이 수행
      allow create: if request.auth != null && memberId == request.resource.data.teamId + '_' + request.auth.uid && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        getTeamMemberRole(resource.data.teamId, request.auth.uid) in ['director', 'manager']
      );
    }

    // =======================================================
    // [Bucket 1, 2] 모임 코어 및 활성화 블록 도메인
    // =======================================================

    match /teams/{teamId} {
      // 1. 방 정보 조회: 퍼블릭 방이거나, 소속 멤버면 조회 가능
      allow read: if resource.data.isPublic == true || 
                  (request.auth != null && getTeamMemberRole(teamId, request.auth.uid) != null);
      
      // 2. 방 메타데이터 및 블록(enabledBlocks) 업데이트: '방장(director)', '임원(manager)' 권한
      allow update: if request.auth != null && getTeamMemberRole(teamId, request.auth.uid) in ['director', 'manager'];
      allow create: if request.auth != null;

      // =======================================================
      // [Bucket 3] 실시간 소통 도메인 (Subcollections)
      // =======================================================

      match /messages/{messageId} {
        // 1. 채팅 읽기 권한
        // 방장(director)과 방원(member)은 무조건 읽을 수 있음.
        // 참관인(supporter)은 본인이 속해있으면 열람 가능.
        allow read: if request.auth != null && getTeamMemberRole(teamId, request.auth.uid) != null;
        
        // 2. 채팅 쓰기 권한
        // 발신자가 본인이어야 하며, 방장/방원만 메시지를 보낼 수 있음 (참관인은 눈팅만 가능)
        allow create: if request.auth != null 
          && request.resource.data.senderId == request.auth.uid
          && getTeamMemberRole(teamId, request.auth.uid) in ['director', 'member'];
          
        allow update, delete: if request.auth != null && (
          request.auth.uid == resource.data.senderId || 
          getTeamMemberRole(teamId, request.auth.uid) in ['director', 'manager']
        );
      }

      match /announcements/{announcementId} {
        // 공지사항 조회: 모든 소속 멤버 가능
        allow read: if request.auth != null && getTeamMemberRole(teamId, request.auth.uid) != null;
        // 공지사항 작성/수정: 방장 및 임원
        allow write: if request.auth != null && getTeamMemberRole(teamId, request.auth.uid) in ['director', 'manager'];
      }
    }
  }
}
